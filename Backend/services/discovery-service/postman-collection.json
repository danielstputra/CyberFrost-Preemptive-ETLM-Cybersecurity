{
  "info": {
    "name": "CYFIRMA Discovery API",
    "description": "Discovery Service — Attack Surface Scanning via BullMQ async workers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Start Scan",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('scanJobId', jsonData.jobId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"domain\": \"example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:4000/api/v1/discovery/scan",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "discovery", "scan"]
        }
      }
    },
    {
      "name": "Get Scan Status",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "http://localhost:4000/api/v1/discovery/scan/{{scanJobId}}",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "discovery", "scan", "{{scanJobId}}"]
        }
      }
    },
    {
      "name": "List All Scans",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "http://localhost:4000/api/v1/discovery/scans?page=1&limit=10",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "discovery", "scans"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "List Discovered Domains",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "http://localhost:4000/api/v1/discovery/domains?page=1&limit=20",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "discovery", "domains"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "Get Domain Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "http://localhost:4000/api/v1/discovery/domains/{{domainId}}",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "discovery", "domains", "{{domainId}}"]
        }
      }
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/api/v1/health",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "health"]
        }
      }
    },
    {
      "name": "Readiness (Discovery Service)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4002/api/v1/health/ready",
          "host": ["http", "localhost"],
          "port": "4002",
          "path": ["api", "v1", "health", "ready"]
        }
      }
    }
  ],
  "variable": [
    { "key": "accessToken", "value": "" },
    { "key": "scanJobId", "value": "" },
    { "key": "domainId", "value": "" }
  ]
}
