{
  "name": "@cyberfrost/report-service",
  "version": "1.0.0",
  "private": true,
  "description": "Report Service — PDF report generation using Puppeteer",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.tsbuildinfo',{recursive:true,force:true})\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "pino": "^10.3.1",
    "puppeteer": "^23.11.1",
    "zod": "^3.24.0",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0"
  }
}
