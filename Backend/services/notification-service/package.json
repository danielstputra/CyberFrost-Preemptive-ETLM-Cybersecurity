{
  "name": "@cyfirma/notification-service",
  "version": "1.0.0",
  "private": true,
  "description": "Notification Service — Real-time alerts via Socket.io, email via Nodemailer, event-driven",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.tsbuildinfo',{recursive:true,force:true})\"",
    "test": "jest --config jest.config.ts --forceExit"
  },
  "dependencies": {
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.4.0",
    "mongoose": "^8.9.0",
    "nodemailer": "^6.9.0",
    "pino": "^10.3.1",
    "socket.io-client": "^4.8.0",
    "zod": "^3.24.0",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
