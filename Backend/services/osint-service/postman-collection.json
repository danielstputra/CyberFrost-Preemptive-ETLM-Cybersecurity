{
  "info": {
    "name": "CYFIRMA OSINT API",
    "description": "OSINT & Scraper — Dark Web Monitoring, Brand Protection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Start OSINT Scan",
      "event": [{
        "listen": "test",
        "script": { "exec": ["var jsonData = pm.response.json();", "pm.collectionVariables.set('osintJobId', jsonData.jobId);"], "type": "text/javascript" }
      }],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"target\": \"example.com\",\n  \"scanType\": \"DOMAIN\"\n}" },
        "url": { "raw": "http://localhost:4000/api/v1/osint/scan", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","scan"] }
      }
    },
    {
      "name": "Get Scan Status",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "http://localhost:4000/api/v1/osint/scan/{{osintJobId}}", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","scan","{{osintJobId}}"] }
      }
    },
    {
      "name": "List Leaks",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "http://localhost:4000/api/v1/osint/leaks?page=1&limit=10", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","leaks"], "query": [{ "key":"page","value":"1"},{ "key":"limit","value":"10"}] }
      }
    },
    {
      "name": "Filter Critical Leaks",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "http://localhost:4000/api/v1/osint/leaks?severity=CRITICAL", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","leaks"], "query": [{ "key":"severity","value":"CRITICAL"}] }
      }
    },
    {
      "name": "Get Leak Detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "http://localhost:4000/api/v1/osint/leaks/{{leakId}}", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","leaks","{{leakId}}"] }
      }
    },
    {
      "name": "Update Leak Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"VERIFIED\"\n}" },
        "url": { "raw": "http://localhost:4000/api/v1/osint/leaks/{{leakId}}/status", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","leaks","{{leakId}}","status"] }
      }
    },
    {
      "name": "List Brand Exposures",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "http://localhost:4000/api/v1/osint/exposures?page=1&limit=10", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","exposures"], "query": [{ "key":"page","value":"1"},{ "key":"limit","value":"10"}] }
      }
    },
    {
      "name": "OSINT Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "http://localhost:4000/api/v1/osint/dashboard", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","osint","dashboard"] }
      }
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:4000/api/v1/health", "host": ["http","localhost"], "port": "4000", "path": ["api","v1","health"] }
      }
    }
  ],
  "variable": [
    { "key": "accessToken", "value": "" },
    { "key": "osintJobId", "value": "" },
    { "key": "leakId", "value": "" }
  ]
}
