{
  "info": {
    "name": "CYFIRMA Auth API",
    "description": "Auth & Tenant Service — API Gateway (port 4000) → Auth Service (port 4001)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('accessToken', jsonData.accessToken);",
              "pm.collectionVariables.set('refreshToken', jsonData.refreshToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@ptcysolusi.com\",\n  \"password\": \"Cyber123!\",\n  \"name\": \"Budi Santoso\",\n  \"tenantName\": \"PT Cyber Solusi Nusantara\",\n  \"tenantSlug\": \"pt-cyber-solusi\"\n}"
        },
        "url": {
          "raw": "http://localhost:4000/api/v1/auth/register",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('accessToken', jsonData.accessToken);",
              "pm.collectionVariables.set('refreshToken', jsonData.refreshToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@ptcysolusi.com\",\n  \"password\": \"Cyber123!\"\n}"
        },
        "url": {
          "raw": "http://localhost:4000/api/v1/auth/login",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "http://localhost:4000/api/v1/auth/refresh",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "auth", "refresh"]
        }
      }
    },
    {
      "name": "Get Profile (Me)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "http://localhost:4000/api/v1/auth/me",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "auth", "me"]
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "http://localhost:4000/api/v1/auth/logout",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "auth", "logout"]
        }
      }
    },
    {
      "name": "Health Check (Gateway)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/api/v1/health",
          "host": ["http", "localhost"],
          "port": "4000",
          "path": ["api", "v1", "health"]
        }
      }
    },
    {
      "name": "Readiness (Auth Service)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4001/api/v1/health/ready",
          "host": ["http", "localhost"],
          "port": "4001",
          "path": ["api", "v1", "health", "ready"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ]
}
